<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.TextFlow?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sudoku.controller.InstructionsController"
            styleClass="instructions-root"
            prefWidth="560" prefHeight="620">

    <top>
        <VBox spacing="4">
            <padding>
                <Insets top="16" right="16" bottom="8" left="16"/>
            </padding>
            <Label text="Instrucciones — Sudoku36" styleClass="instructions-title"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="instructions-scroll">
            <padding>
                <Insets left="16" right="16"/>
            </padding>
            <TextFlow fx:id="instructionsText" styleClass="instructions-body"/>
        </ScrollPane>
    </center>

    <bottom>
        <VBox alignment="CENTER">
            <padding>
                <Insets top="8" right="16" bottom="16" left="16"/>
            </padding>
            <Button text="Cerrar" onAction="#handleClose" styleClass="menu-primary-button" defaultButton="true"/>
        </VBox>
    </bottom>

</BorderPane>
